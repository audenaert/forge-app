# API origin used by the web client at runtime.
VITE_API_URL=http://localhost:4000/graphql

# API key sent with requests during local development.
# Use `seed-dev-key` to authenticate against the demo `seed` domain created
# by `npm run seed` (see scripts/README.md). This key is a well-known dev-only
# constant — do NOT reuse it in any production domain.
VITE_API_KEY=seed-dev-key
