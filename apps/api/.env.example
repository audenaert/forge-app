# -----------------------------------------------------------------------------
# @forge-workspace/api runtime environment
#
# Every environment variable referenced in apps/api source (directly or via
# packages/graph's driver module) must be listed here. If you add a new
# `process.env.X` reference in apps/api or packages/graph, add it to this file
# at the same time — this file is the single source of truth for the API
# server's env surface.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Server (apps/api/src/server.ts)
# -----------------------------------------------------------------------------

# HTTP port the GraphQL server listens on.
PORT=4000

# Set to "true" to skip API key auth during local development. Any request is
# resolved to the `default` domain. Never enable this in a deployed environment.
# DISABLE_AUTH=true

# -----------------------------------------------------------------------------
# Neo4j driver (packages/graph/src/driver.ts — consumed by apps/api and by
# scripts/seed.ts)
#
# These vars live in packages/graph's driver factory but are resolved from the
# environment of whatever process instantiates the driver. For apps/api, that's
# this file. For scripts/seed.ts, the same values are read from the shell
# environment when `npm run seed` runs — keep them aligned.
# -----------------------------------------------------------------------------

# Bolt URI of the Neo4j instance. Matches the port exposed by docker-compose.yml.
NEO4J_URI=bolt://localhost:7687

# Neo4j auth. Must match the NEO4J_AUTH value in docker-compose.yml
# (`neo4j/forgedev` for the default local dev stack).
NEO4J_USER=neo4j
NEO4J_PASSWORD=forgedev
